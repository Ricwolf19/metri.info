# ── METRI web environment ───────────────────────────────────────────────────
# Local development: copy this file to `.env` and fill in your DEV values.
# Bun auto-loads `.env`, so `bun dev`, `bun run db:migrate`, etc. pick it up.
# Production: set these in the Vercel project (Settings → Environment Variables).
# Never commit a real `.env` — it is gitignored.

# Public site URL (no trailing slash). MUST match the CANONICAL prod domain
# exactly (apex vs www) — it is the auth baseURL and is inlined at build time,
# so redeploy after changing it. Dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Extra origins allowed to call the auth API (comma-separated, no trailing
# slash). The apex + www of NEXT_PUBLIC_APP_URL are trusted automatically; use
# this only for additional domains (e.g. preview URLs). Usually leave blank.
BETTER_AUTH_TRUSTED_ORIGINS=

# Neon Postgres connection string (use the POOLED url, ends in -pooler).
# Dev: a dedicated Neon branch. Prod: the production branch (set in Vercel).
DATABASE_URL=

# Better Auth signing secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# OAuth (optional — social sign-in buttons appear only when a pair is set).
# Dev callback URLs: http://localhost:3000/api/auth/callback/{github,google}
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Analytics 4 (optional). Leave blank in dev to avoid polluting metrics.
NEXT_PUBLIC_GA_ID=

# PostHog product analytics — autocapture, heatmaps, session replay. The two
# public vars load the client SDK (leave blank in dev to avoid polluting
# metrics). POSTHOG_PERSONAL_API_KEY is server-only: it powers the in-app
# /admin dashboards via the Query API (create one under Project → Personal API
# keys with "query:read"). Never expose it to the client.
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# Admin bootstrap (used only by `bun run admin:bootstrap`, never at runtime).
# Email defaults to rhtc19@gmail.com; password is generated + printed once if
# left blank. Set ADMIN_PASSWORD to choose your own. Do NOT commit a real value.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Contact form (Resend + reCAPTCHA) ───────────────────────────────────────
# Resend API key — required for the contact form to deliver mail.
RESEND_API_KEY=
# Inbox that contact messages are delivered to. Defaults to rhtc19@gmail.com.
CONTACT_TO_EMAIL=
# Sender address. Resend's shared "onboarding@resend.dev" works in test mode for
# delivering to the account owner; use a verified-domain sender for production.
CONTACT_FROM_EMAIL=
# Sender for password-reset emails (reuses RESEND_API_KEY). Optional — falls
# back to CONTACT_FROM_EMAIL, then to "onboarding@resend.dev". If RESEND_API_KEY
# is unset, reset emails are skipped with a warning (no crash).
AUTH_FROM_EMAIL=

# reCAPTCHA v3 keys (optional but recommended in prod — bot protection). When
# both are blank the form still works and verification is skipped (dev).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Sentry (error monitoring + tracing) ─────────────────────────────────────
# DSN is the only required var; everything else is optional and gates features.
# Find your DSN at: sentry.io → Settings → Projects → javascript-nextjs →
# Client Keys (DSN). Both server and client can share the same DSN.
#   NEXT_PUBLIC_SENTRY_DSN is exposed to the browser bundle (read-only).
#   SENTRY_DSN stays server-side only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Auth token for uploading source maps at build time — used by
# `withSentryConfig` only during `bun run build`. Recommended: an Organization
# Auth Token (pre-scoped for releases/source maps) at
# sentry.io → Settings → Auth Tokens → "Create New Token". A User Auth Token
# with `project:releases` works too.
SENTRY_AUTH_TOKEN=
# Read token for the admin dashboard's Sentry panel (error volume + top issues).
# Different from SENTRY_AUTH_TOKEN: this needs READ scopes. Create a User Auth
# Token at sentry.io → Settings → Account → User Auth Tokens with
# `event:read project:read org:read`. Org/project default to next.config.ts.
SENTRY_API_TOKEN=
# SENTRY_ORG=metri-ku
# SENTRY_PROJECT=javascript-nextjs
#
# Rate-limit caps are hardcoded with safe defaults in `lib/auth/server.ts`.
# See AGENTS.md → "Auth & email" for how to bump them temporarily without
# a redeploy (or set BETTER_AUTH_RATE_LIMIT_ENABLED=false to disable).
