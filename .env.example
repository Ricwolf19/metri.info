# ── METRI web environment ───────────────────────────────────────────────────
# Local development: copy this file to `.env` and fill in your DEV values.
# Bun auto-loads `.env`, so `bun dev`, `bun run db:migrate`, etc. pick it up.
# Production: set these in the Vercel project (Settings → Environment Variables).
# Never commit a real `.env` — it is gitignored.

# Public site URL (no trailing slash). MUST match the CANONICAL prod domain
# exactly (apex vs www) — it is the auth baseURL and is inlined at build time,
# so redeploy after changing it. Dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Extra origins allowed to call the auth API (comma-separated, no trailing
# slash). The apex + www of NEXT_PUBLIC_APP_URL are trusted automatically; use
# this only for additional domains (e.g. preview URLs). Usually leave blank.
BETTER_AUTH_TRUSTED_ORIGINS=

# Neon Postgres connection string (use the POOLED url, ends in -pooler).
# Dev: a dedicated Neon branch. Prod: the production branch (set in Vercel).
DATABASE_URL=

# Better Auth signing secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# OAuth (optional — social sign-in buttons appear only when a pair is set).
# Dev callback URLs: http://localhost:3000/api/auth/callback/{github,google}
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Analytics 4 (optional). Leave blank in dev to avoid polluting metrics.
NEXT_PUBLIC_GA_ID=

# ── Contact form (Resend + reCAPTCHA) ───────────────────────────────────────
# Resend API key — required for the contact form to deliver mail.
RESEND_API_KEY=
# Inbox that contact messages are delivered to. Defaults to rhtc19@gmail.com.
CONTACT_TO_EMAIL=
# Sender address. Resend's shared "onboarding@resend.dev" works in test mode for
# delivering to the account owner; use a verified-domain sender for production.
CONTACT_FROM_EMAIL=

# reCAPTCHA v3 keys (optional but recommended in prod — bot protection). When
# both are blank the form still works and verification is skipped (dev).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
