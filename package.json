{
  "name": "metri.info",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint:circular": "madge --circular --extensions ts,tsx app components lib",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check --ignore-path .gitignore .",
    "format:fix": "prettier --write --ignore-path .gitignore .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "gen:favicons": "node scripts/gen-favicons.mjs",
    "ci": "bun run format && bun run lint && bun run typecheck && bun run lint:circular && bun run build",
    "verify": "bun run ci",
    "prepare": "husky"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.9",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@img/sharp-darwin-arm64": "0.35.1",
    "@img/sharp-libvips-darwin-arm64": "^1.3.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "madge": "^8.0.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "secretlint": "^13.0.2",
    "sharp": "^0.35.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
